@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
participant ":VersionedHomeChef" as VersionedHomeChef MODEL_COLOR
end box

[-> Model : undoHomeChef()
activate Model

Model -> VersionedHomeChef : undo()
activate VersionedHomeChef

VersionedHomeChef -> VersionedHomeChef :resetData(ReadOnlyHomeChef)
VersionedHomeChef --> Model :
deactivate VersionedHomeChef

[<-- Model
deactivate Model

@enduml
